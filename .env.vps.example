APP_DOMAIN=app.suzukicello.ch
PUBLIC_APP_ORIGIN=https://app.suzukicello.ch

POSTGRES_DB=suzuki_cello
POSTGRES_USER=suzuki
POSTGRES_PASSWORD=replace-with-a-long-random-database-password

SESSION_SECRET=replace-with-a-long-random-session-secret

ADMIN_EMAIL=teacher@example.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_NAME=Teacher

# Cloudflare Pages host that serves /api/media/* (Caddy proxies to it)
MEDIA_UPSTREAM=suzuki-cello-school.pages.dev
